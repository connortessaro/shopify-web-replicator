{
  "name": "@shopify-web-replicator/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./dist/http.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@shopify-web-replicator/engine": "workspace:*",
    "@shopify-web-replicator/shared": "workspace:*",
    "zod": "^4.1.5"
  }
}
