{% comment %}
  Placeholder product output for the Shopify Web Replicator pipeline.
{% endcomment %}

<section class="generated-product-reference full-width">
  <div class="generated-product-reference__content">
    <p class="generated-product-reference__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ product.title | default: section.settings.heading }}</h1>
    <p class="generated-product-reference__body">{{ section.settings.body }}</p>
    <p class="generated-product-reference__meta">{{ section.settings.mapping_summary }}</p>

    {% if product != blank %}
      {% form 'product', product %}
        <button type="submit">{{ section.settings.cta_label }}</button>
      {% endform %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Generated product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Generated product" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product replication workspace" },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This file is the stable output target for generated product Liquid."
    },
    {
      "type": "textarea",
      "id": "mapping_summary",
      "label": "Mapping summary",
      "default": "The deterministic product pipeline will replace this placeholder."
    },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add to cart" }
  ]
}
{% endschema %}
