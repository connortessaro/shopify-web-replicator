{% comment %}
  Generated by Shopify Web Replicator.
  Source: https://kip.life/products/the-disconnect-tag
  Mapping summary: Mapped The Disconnect Tag into the stable generated product template.
{% endcomment %}

<section class="generated-product-reference full-width">
  <div class="generated-product-reference__content">
    {% if section.settings.eyebrow != blank %}
      <p class="generated-product-reference__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 600 | image_tag: class: "generated-product-reference__image", loading: 'lazy' }}
    {% endif %}
    <h1>{{ product.title | default: section.settings.heading }}</h1>
    <p class="generated-product-reference__body">{{ section.settings.body }}</p>

    {% if product != blank %}
      <div class="generated-product-reference__price">{{ product.price | money }}</div>
      {% form 'product', product %}
        <button class="generated-product-reference__cta" type="submit">
          {{ section.settings.cta_label }}
        </button>
      {% endform %}
    {% else %}
      <p class="generated-product-reference__empty">Connect this template to a product to validate the generated purchase flow.</p>
    {% endif %}


    {% render 'generated-commerce-wiring', page_type: 'product_page' %}

  </div>
</section>

{% stylesheet %}
  .generated-product-reference {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: 80px 0;
    background: linear-gradient(180deg, #fffdf5 0%, #eef4df 100%);
  }

  .generated-product-reference__content {
    grid-column: 2;
    padding: 0 24px;
    max-width: 760px;
  }

  .generated-product-reference__image {
    width: 100%;
    max-width: 480px;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .generated-product-reference__eyebrow,
  .generated-product-reference__empty {
    color: #335144;
  }

  .generated-product-reference__price {
    margin-top: 1.5rem;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .generated-product-reference__cta {
    margin-top: 1rem;
    padding: 0.95rem 1.4rem;
    border: 0;
    border-radius: 999px;
    color: #fffdf5;
    background-color: #17362b;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Generated product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "kip.life"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading fallback",
      "default": "The Disconnect Tag"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "The Disconnect Tag is prepared as a Shopify-native product page with add-to-cart flow ready for operator QA."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Add to cart"
    }
  ]
}
{% endschema %}
