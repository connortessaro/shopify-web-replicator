{% comment %}
  Placeholder collection output for the Shopify Web Replicator pipeline.
{% endcomment %}

<section class="generated-collection-reference full-width">
  <div class="generated-collection-reference__content">
    <p class="generated-collection-reference__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ collection.title | default: section.settings.heading }}</h1>
    <p class="generated-collection-reference__body">{{ section.settings.body }}</p>
    <p class="generated-collection-reference__meta">{{ section.settings.mapping_summary }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Generated collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Generated collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collection replication workspace" },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This file is the stable output target for generated collection Liquid."
    },
    {
      "type": "textarea",
      "id": "mapping_summary",
      "label": "Mapping summary",
      "default": "The deterministic collection pipeline will replace this placeholder."
    }
  ]
}
{% endschema %}
